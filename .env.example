# OHAYO! 환경 변수 예시
# 이 파일을 .env.local로 복사한 뒤 값을 채워주세요.
# .env.local은 절대 Git에 커밋하지 마세요.

# ── Supabase (M2에서 필요) ──────────────────
# Supabase 프로젝트 Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Supabase Service Role Key (서버 전용, 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Gemini AI (M5에서 필요) ─────────────────
# Google AI Studio에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ── Vercel Cron 보안 (M4에서 필요) ──────────
# 크롤링 API(/api/cron/collect)를 보호하는 시크릿 토큰
CRON_SECRET=your_random_secret_string_here

# ── 앱 설정 ────────────────────────────────
# 배포 URL (Vercel 배포 시 자동 설정됨)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
