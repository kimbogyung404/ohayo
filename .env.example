# OHAYO! 환경 변수 예시
# 이 파일을 .env.local로 복사한 뒤 값을 채워주세요.
# .env.local은 절대 Git에 커밋하지 마세요.

# ── Supabase (M2에서 필요) ──────────────────
# Supabase 프로젝트 Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Supabase Service Role Key (서버 전용, 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Gemini AI (M5에서 필요) ─────────────────
# Google AI Studio(https://aistudio.google.com/apikey)에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 모델 (미설정 시 코드 기본값 gemini-3.1-flash-lite 사용)
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Vercel Cron 보안 (M4/M5에서 필요) ───────
# 크롤링/학습데이터 생성 API(/api/cron/collect, /api/cron/generate)를 보호하는 시크릿 토큰
CRON_SECRET=your_random_secret_string_here

# ── Mixpanel 분석 ──────────────────────────
# Mixpanel 프로젝트 Settings > Project Settings에서 확인
# 주의: NEXT_PUBLIC_ 변수는 빌드 타임에 번들에 인라인되므로,
# Vercel Production/Preview 환경 변수에도 반드시 등록해야 한다
# (.env.local에만 있으면 로컬에서만 동작하고 배포본에서는 비활성화된다).
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token_here

# ── 앱 설정 ────────────────────────────────
# 배포 URL (Vercel 배포 시 자동 설정됨)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
